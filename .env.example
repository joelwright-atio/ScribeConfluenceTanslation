# --- Scribe ---
# Your Scribe API key (from app.scribehow.com → Settings → API)
SCRIBE_API_KEY=

# --- Translation (DeepL) ---
# Get from www.deepl.com/pro-api → Account → Authentication Key
DEEPL_API_KEY=

# --- Confluence REST API ---
# Your Atlassian site, e.g. https://your-org.atlassian.net
CONFLUENCE_BASE_URL=

# The email address tied to your Atlassian account
CONFLUENCE_USERNAME=

# Atlassian API token (id.atlassian.com → Security → API tokens)
CONFLUENCE_API_TOKEN=

# The space key where SOPs will be published, e.g. SOP or HANDBOOK
CONFLUENCE_SPACE_KEY=

# Optional: parent page ID to nest SOPs under (visible in the page URL)
CONFLUENCE_PARENT_PAGE_ID=

# --- Pipeline settings ---
# Target language for translation, e.g. de, fr, es
TARGET_LANGUAGE=de

# Path to the folder where Scribe markdown exports are dropped
INPUT_DIR=input

# Path for translated markdown before upload (optional intermediate step)
OUTPUT_DIR=output
